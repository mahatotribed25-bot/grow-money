
{
  "entities": {
    "user": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "role": {
          "type": "string",
          "enum": ["user", "subadmin"],
          "description": "The role of the user, determining their access level."
        },
        "walletBalance": {
          "type": "number",
          "description": "The user's current wallet balance."
        },
        "totalInvestment": {
          "type": "number",
          "description": "The total amount the user has invested."
        },
        "totalIncome": {
          "type": "number",
          "description": "The total income the user has earned from investments."
        },
        "status": {
            "type": "string",
            "enum": ["Active", "Blocked"]
        },
        "trustScore": {
            "type": "number"
        }
      },
      "required": [
        "uid",
        "email"
      ]
    },
    "walletTransaction": {
        "title": "Wallet Transaction",
        "description": "A record of a credit or debit to a user's wallet.",
        "type": "object",
        "properties": {
            "amount": { "type": "number" },
            "type": { "type": "string", "enum": ["credit", "debit"] },
            "category": { "type": "string" },
            "description": { "type": "string" },
            "createdAt": { "type": "string", "format": "date-time" }
        }
    },
    "investmentPlan": {
        "title": "Investment Plan",
        "type": "object",
        "properties": {
            "name": { "type": "string" },
            "price": { "type": "number" },
            "dailyIncome": { "type": "number" },
            "validity": { "type": "number" }
        }
    },
    "scratchCard": {
      "title": "Scratch Card",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["unscratched", "scratched"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "scratchedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/user"
      },
      "description": "Stores user profile information."
    },
    "/users/{userId}/walletHistory/{txId}": {
        "schema": { "$ref": "#/entities/walletTransaction" },
        "description": "Logs every balance change for the user."
    },
    "/scratchCards/{cardId}": {
      "schema": { "$ref": "#/entities/scratchCard" },
      "description": "Stores issued scratch cards."
    },
    "/settings/admin": {
      "schema": { "type": "object" },
      "description": "Stores admin-specific settings."
    }
  }
}
