
{
  "entities": {
    "user": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "role": {
          "type": "string",
          "enum": ["user", "subadmin"],
          "description": "The role of the user, determining their access level."
        },
        "permissions": {
            "type": "object",
            "description": "Specific permissions for sub-admin users.",
            "properties": {
                "canManageDeposits": { "type": "boolean", "description": "Can approve/reject deposit requests." },
                "canManageWithdrawals": { "type": "boolean", "description": "Can approve/reject withdrawal requests." },
                "canManageKyc": { "type": "boolean", "description": "Can approve/reject KYC requests." },
                "canManagePlanLoans": { "type": "boolean", "description": "Can approve/reject standard loan plan requests." },
                "canManageCustomLoans": { "type": "boolean", "description": "Can manage the entire custom loan lifecycle." }
            }
        },
        "walletBalance": {
          "type": "number",
          "description": "The user's current wallet balance."
        },
        "totalInvestment": {
          "type": "number",
          "description": "The total amount the user has invested."
        },
        "totalIncome": {
          "type": "number",
          "description": "The total income the user has earned from investments."
        },
        "referralCode": {
          "type": "string",
          "description": "The user's unique referral code."
        },
        "referredBy": {
          "type": "string",
          "description": "The UID of the user who referred this user."
        },
        "status": {
            "type": "string",
            "enum": ["Active", "Blocked"],
            "description": "The status of the user's account."
        },
        "upiId": {
          "type": "string",
          "description": "The user's verified UPI ID for receiving withdrawals."
        },
        "upiProvider": {
            "type": "string",
            "enum": ["PhonePe", "Google Pay", "Paytm"],
            "description": "The provider for the user's verified UPI ID."
        },
        "upiStatus": {
            "type": "string",
            "enum": ["Unverified", "Pending", "Verified", "Rejected"],
            "description": "The verification status of the user's UPI ID."
        },
        "panCard": {
            "type": "string",
            "description": "The user's PAN card number."
        },
        "aadhaarNumber": {
            "type": "string",
            "description": "The user's 12-digit Aadhaar card number."
        },
        "phoneNumber": {
            "type": "string",
            "description": "The user's phone number."
        },
        "kycTermsAccepted": {
            "type": "boolean",
            "description": "Indicates if the user has accepted the KYC terms and conditions for loans."
        },
        "kycStatus": {
            "type": "string",
            "enum": ["Not Submitted", "Pending", "Verified", "Rejected"],
            "description": "The verification status of the user's KYC documents."
        },
        "kycRejectionReason": {
            "type": "string",
            "description": "The reason provided by the admin for rejecting a KYC submission."
        },
        "kycSubmissionDate": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp when the user submitted their KYC details."
        },
        "isOnline": {
            "type": "boolean",
            "description": "Indicates if the user is currently online."
        },
        "lastSeen": {
            "type": "string",
            "format": "date-time",
            "description": "The last time the user was seen online."
        },
        "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the user account was created."
        },
        "vipLevel": {
          "type": "string",
          "enum": ["Bronze", "Silver", "Gold", "Platinum"],
          "description": "The VIP level of the user, determining their benefits."
        },
        "trustScore": {
            "type": "number",
            "description": "The user's internal trust score, calculated based on their activity."
        },
        "lastCheckIn": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp of the user's last daily check-in."
        }
      },
      "required": [
        "uid",
        "email"
      ]
    },
    "userChatSession": {
      "title": "User Chat Session",
      "description": "A chat session between two users, initiated by an admin.",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" }, "description": "UIDs of the two users." },
        "participantNames": { "type": "object", "description": "Map of UID to Name." },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "userChatMessage": {
        "title": "User Chat Message",
        "description": "A message in a peer-to-peer chat.",
        "type": "object",
        "properties": {
            "text": { "type": "string" },
            "senderId": { "type": "string" },
            "createdAt": { "type": "string", "format": "date-time" }
        }
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/user"
      },
      "description": "Stores user profile information."
    },
    "/settings/admin": {
      "schema": {
        "$ref": "#/entities/adminSettings"
      },
      "description": "Stores admin-specific settings."
    },
    "/chats/{userId}": {
      "schema": { "$ref": "#/entities/chat" },
      "description": "Stores a chat session between a user and an admin."
    },
    "/chats/{userId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/chatMessage" },
      "description": "Stores individual messages within a chat session."
    },
    "/userChatSessions/{sessionId}": {
        "schema": { "$ref": "#/entities/userChatSession" },
        "description": "Stores connections between users for private chatting."
    },
    "/userChatSessions/{sessionId}/messages/{messageId}": {
        "schema": { "$ref": "#/entities/userChatMessage" },
        "description": "Stores messages between connected users."
    }
  }
}
