
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "admin@tribed.world";
    }

    function isSubAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'subadmin';
    }

    // Rules for 'users'
    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read: if isAuthenticated();
      allow update: if isOwner(userId) || isAdmin() || isSubAdmin();
      allow delete: if isAdmin();
    }

    // Settings
    match /settings/admin {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Marketplace
    match /p2pLoanRequests/{id} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
        allow delete: if isAdmin();
    }
    match /p2pLoanRequests/{id}/offers/{offerId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
        allow delete: if isAdmin();
    }

    // Legacy matchers...
    match /announcements/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isSubAdmin();
    }
    match /investmentPlans/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /loanPlans/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /groupLoanPlans/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /groupLoanPlans/{planId}/investments/{id} {
      allow read: if isAuthenticated() && (resource.data.investorId == request.auth.uid || isAdmin() || isSubAdmin());
      allow create: if isAuthenticated() && request.resource.data.investorId == request.auth.uid;
      allow update, delete: if isAdmin() || isSubAdmin();
    }
    match /deposits/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin() || isSubAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || isSubAdmin();
    }
    match /withdrawals/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin() || isSubAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || isSubAdmin();
    }
    match /loanRequests/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin() || isSubAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || isSubAdmin();
    }
    match /upiRequests/{id} {
        allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin() || isSubAdmin());
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin() || isSubAdmin();
    }
    match /customLoanRequests/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin() || isSubAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin() || isSubAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
