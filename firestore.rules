
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (request.auth.token.email == "admin@tribed.world" || request.auth.token.email == "admin@tribed.com");
    }

    function isSubAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'subadmin';
    }
    
    function isManager() {
      return isAdmin() || isSubAdmin();
    }

    // COLLECTION GROUP RULES - Required for Activity Pulse and Admin Dashboard stats
    match /{path=**}/investments/{id} {
      allow list, get: if isAuthenticated();
      allow write: if isManager();
    }
    match /{path=**}/loans/{id} {
      allow list, get: if isAuthenticated();
      allow write: if isManager();
    }
    match /{path=**}/offers/{id} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
    }
    match /{path=**}/messages/{id} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
    }

    // Rules for 'users'
    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read: if isAuthenticated();
      allow update: if isAuthenticated(); 
      allow delete: if isAdmin();

      // User's own financial sub-collections (Direct path)
      match /investments/{id} {
        allow read, write: if isOwner(userId) || isManager();
      }
      match /loans/{id} {
        allow read, write: if isOwner(userId) || isManager();
      }
    }

    // Settings
    match /settings/admin {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    // P2P Marketplace
    match /p2pLoanRequests/{id} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
        allow delete: if isManager();
        
        match /offers/{offerId} {
            allow read: if isAuthenticated();
            allow create: if isAuthenticated();
            allow update: if isAuthenticated();
            allow delete: if isManager();
        }
    }
    
    match /p2pActiveLoans/{id} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
        allow delete: if isManager();
    }
    
    match /p2pHistory/{id} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
    }

    // Announcements
    match /announcements/{id} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    // Coupons
    match /coupons/{id} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Investment Plans
    match /investmentPlans/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow update: if isAuthenticated();
    }
    
    // Group Loan Plans
    match /groupLoanPlans/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow update: if isAuthenticated();
      
      match /investments/{invId} {
          allow read, write: if isAuthenticated();
      }
      
      match /repayments/{repId} {
          allow read, write: if isManager();
      }
      
      match /payouts/{payId} {
          allow read, write: if isManager();
      }
    }

    // Standard transactions
    match /deposits/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isManager();
    }
    match /withdrawals/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isManager();
    }
    match /loanRequests/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isManager();
    }
    match /upiRequests/{id} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isManager();
    }
    match /customLoanRequests/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() || isManager(); 
      allow delete: if isManager();
    }

    // Admin Specific history
    match /adminWithdrawals/{id} {
      allow read, write: if isAdmin();
    }

    // Chat support
    match /chats/{chatId} {
        allow read, write: if isOwner(chatId) || isManager();
        match /messages/{msgId} {
            allow read, write: if isOwner(chatId) || isManager();
        }
    }
    
    // Private user chats (Bridged)
    match /userChatSessions/{sessionId} {
        allow read: if isAuthenticated() && (request.auth.uid in resource.data.participants || isManager());
        allow create: if isManager();
        allow update: if isAuthenticated() && (request.auth.uid in resource.data.participants);
        allow delete: if isManager();
        
        match /messages/{msgId} {
            allow read, write: if isAuthenticated();
        }
    }

    // Global Admin catch-all
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
