
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "admin@tribed.world";
    }

    function isSubAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'subadmin';
    }

    // Rules for 'users'
    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read: if isAuthenticated();
      // Allow update if owner, admin, or for P2P transaction balance adjustments
      allow update: if isAuthenticated(); 
      allow delete: if isAdmin();
    }

    // Settings
    match /settings/admin {
      allow read: if isAuthenticated();
      // Allow write for Admin and for P2P fee profit recording
      allow write: if isAuthenticated();
    }

    // Marketplace
    match /p2pLoanRequests/{id} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
        allow delete: if isAdmin();
        
        match /offers/{offerId} {
            allow read: if isAuthenticated();
            allow create: if isAuthenticated();
            allow update: if isAuthenticated();
            allow delete: if isAdmin();
        }
    }
    
    match /p2pHistory/{id} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
    }

    // Announcements
    match /announcements/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isSubAdmin();
    }
    
    // Investment Plans
    match /investmentPlans/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow update: if isAuthenticated(); // For stock updates
    }
    
    // Group Loan Plans
    match /groupLoanPlans/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow update: if isAuthenticated(); // For funding updates
      
      match /investments/{invId} {
          allow read: if isAuthenticated();
          allow create: if isAuthenticated();
          allow update: if isAdmin() || isSubAdmin();
      }
      
      match /repayments/{repId} {
          allow read: if isAuthenticated();
          allow write: if isAdmin() || isSubAdmin();
      }
      
      match /payouts/{payId} {
          allow read: if isAuthenticated();
          allow write: if isAdmin() || isSubAdmin();
      }
    }

    // Standard transactions
    match /deposits/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isSubAdmin();
    }
    match /withdrawals/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isSubAdmin();
    }
    match /loanRequests/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isSubAdmin();
    }
    match /upiRequests/{id} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
    }
    match /customLoanRequests/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    // Chat support
    match /chats/{chatId} {
        allow read, write: if isOwner(chatId) || isAdmin();
        match /messages/{msgId} {
            allow read, write: if isOwner(chatId) || isAdmin();
        }
    }
    
    // Private user chats
    match /userChatSessions/{sessionId} {
        allow read: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin());
        allow create: if isAdmin();
        allow update: if isAuthenticated() && (request.auth.uid in resource.data.participants);
        allow delete: if isAdmin();
        
        match /messages/{msgId} {
            allow read, write: if isAuthenticated();
        }
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
