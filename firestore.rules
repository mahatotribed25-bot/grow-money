
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "admin@tribed.world";
    }

    function isSubAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'subadmin';
    }

    // Rules for 'users'
    match /users/{userId} {
      allow create: if isOwner(userId);
      // Allow read for all authenticated users to support Leaderboard and P2P participant names
      allow read: if isAuthenticated();
      // Allow update for balance adjustments (P2P/Investments), profile updates, and VIP leveling
      allow update: if isAuthenticated(); 
      allow delete: if isAdmin();

      // User's own financial sub-collections (Direct path)
      match /investments/{id} {
        allow read: if isOwner(userId) || isAdmin() || isSubAdmin();
        allow write: if isOwner(userId) || isAdmin() || isSubAdmin();
      }
      match /loans/{id} {
        allow read: if isOwner(userId) || isAdmin() || isSubAdmin();
        allow write: if isAdmin() || isSubAdmin();
        allow update: if isOwner(userId); // For user to signal payment pending
      }
    }

    // Collection Group Rules (For Admin Dashboard stats and cross-user lookups)
    match /{path=**}/investments/{id} {
      allow read: if isAuthenticated();
    }
    match /{path=**}/loans/{id} {
      allow read: if isAuthenticated();
    }
    match /{path=**}/offers/{id} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
    }
    match /{path=**}/messages/{id} {
        allow read, write: if isAuthenticated();
    }

    // Settings
    match /settings/admin {
      allow read: if isAuthenticated();
      // Allow write for Admin and for P2P fee profit recording/stock decrement (triggered by users during transactions)
      allow write: if isAuthenticated();
    }

    // P2P Marketplace
    match /p2pLoanRequests/{id} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
        allow delete: if isAdmin();
        
        match /offers/{offerId} {
            allow read: if isAuthenticated();
            allow create: if isAuthenticated();
            allow update: if isAuthenticated();
            allow delete: if isAdmin();
        }
    }
    
    match /p2pHistory/{id} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
    }

    // Announcements
    match /announcements/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isSubAdmin();
    }

    // Coupons
    match /coupons/{id} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated(); // For stock decrement and redemptions array update
      allow write: if isAdmin();
    }
    
    // Investment Plans
    match /investmentPlans/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow update: if isAuthenticated(); // For stock/limit updates during purchase
    }
    
    // Group Loan Plans
    match /groupLoanPlans/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow update: if isAuthenticated(); // For funding updates
      
      match /investments/{invId} {
          allow read: if isAuthenticated();
          allow create: if isAuthenticated();
          allow update: if isAdmin() || isSubAdmin();
      }
      
      match /repayments/{repId} {
          allow read: if isAuthenticated();
          allow write: if isAdmin() || isSubAdmin();
      }
      
      match /payouts/{payId} {
          allow read: if isAuthenticated();
          allow write: if isAdmin() || isSubAdmin();
      }
    }

    // Loan Plans (Static definitions)
    match /loanPlans/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Standard transactions
    match /deposits/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isSubAdmin();
    }
    match /withdrawals/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isSubAdmin();
    }
    match /loanRequests/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isSubAdmin();
    }
    match /upiRequests/{id} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAdmin() || isSubAdmin();
    }
    match /customLoanRequests/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() || isAdmin() || isSubAdmin(); 
    }

    // Admin Specific history
    match /adminWithdrawals/{id} {
      allow read, write: if isAdmin();
    }

    // Chat support
    match /chats/{chatId} {
        allow read, write: if isOwner(chatId) || isAdmin() || isSubAdmin();
        match /messages/{msgId} {
            allow read, write: if isOwner(chatId) || isAdmin() || isSubAdmin();
        }
    }
    
    // Private user chats (Bridged)
    match /userChatSessions/{sessionId} {
        allow read: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin() || isSubAdmin());
        allow create: if isAdmin() || isSubAdmin();
        allow update: if isAuthenticated() && (request.auth.uid in resource.data.participants);
        allow delete: if isAdmin() || isSubAdmin();
        
        match /messages/{msgId} {
            allow read, write: if isAuthenticated();
        }
    }

    // Global Admin catch-all
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
